# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=hr_system
DB_USER=hr_user
DB_PASSWORD=hr_password

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=52428800

# ── Security — REQUIRED (لا تشغّل النظام بدون تغيير هذه القيمة) ─────────────
# توليد مفتاح قوي: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_A_STRONG_RANDOM_64_CHAR_SECRET

# ── CORS (اختياري — اتركه فارغاً للسماح بنفس المصدر فقط) ──────────────────
# ALLOWED_ORIGINS=http://192.168.1.100:3000
